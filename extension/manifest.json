{
  "manifest_version": 3,
  "name": "OfficeGit",
  "version": "1.0.0",
  "description": "Upload, browse, and manage your OfficeGit documents directly from Chrome.",
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "notifications"
  ],
  "host_permissions": [
    "http://localhost:5000/*",
    "https://*.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
